<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <title>Nos formules - JC Service</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      font-family: Poppins, sans-serif;
      margin: 0;
      padding: 40px;
      background: #f9f9f9;
    }

    h1 {
      text-align: center;
      margin-bottom: 40px;
    }

    .formules {
      display: flex;
      gap: 20px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .plan {
      width: 280px;
      padding: 25px;
      border-radius: 12px;
      background: #eee;
      text-align: center;
      transition: 0.3s;
      opacity: 0.6;
    }

    .plan.active {
      background: #ff7a00;
      color: white;
      transform: scale(1.05);
      opacity: 1;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .price {
      font-size: 22px;
      font-weight: bold;
      margin: 15px 0;
    }

    .btn {
      display: inline-block;
      padding: 10px 20px;
      background: black;
      color: white;
      border-radius: 6px;
      text-decoration: none;
      margin-top: 10px;
    }

    .plan.active .btn {
      background: white;
      color: #ff7a00;
    }
  </style>
</head>

<body>

<h1>Nos formules d’entretien</h1>

<div class="formules">

  <div class="plan" data-plan="essentiel">
    <h3>Essentiel</h3>
    <p class="price">À partir de 100€</p>
    <a href="#" class="btn">Choisir</a>
  </div>

  <div class="plan" data-plan="confort">
    <h3>Confort</h3>
    <p class="price">À partir de 130€</p>
    <a href="#" class="btn">Choisir</a>
  </div>

  <div class="plan" data-plan="privilege">
    <h3>Privilège</h3>
    <p class="price">À partir de 160€</p>
    <a href="#" class="btn">Choisir</a>
  </div>

</div>

<script>
  const params = new URLSearchParams(window.location.search);
  const plan = params.get("plan");

  if (plan) {
    document.querySelectorAll(".plan").forEach(p => {
      p.classList.remove("active");
    });

    const selected = document.querySelector(`[data-plan="${plan}"]`);
    if (selected) {
      selected.classList.add("active");

      selected.scrollIntoView({
        behavior: "smooth",
        block: "center"
      });
    }
  }
</script>

</body>
</html>
